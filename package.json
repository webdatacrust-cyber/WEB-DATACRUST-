{
  "name": "startup-platform",
  "version": "1.2.0",
  "private": true,
  "scripts": {
    "dev": "npm run prisma:setup:dev && next dev",
    "prisma:setup:dev": "prisma generate --schema=./prisma/schema.prisma",
    "build": "prisma generate --schema=./prisma/schema.prisma && next build",
    "migrate:repair:render": "prisma migrate resolve --rolled-back 20260315120000_postgres_baseline --schema=./prisma/schema.prisma || true",
    "build:render": "npm run migrate:repair:render && prisma migrate deploy --schema=./prisma/schema.prisma && npm run build",
    "start": "next start",
    "start:render": "prisma migrate deploy --schema=./prisma/schema.prisma && next start",
    "lint": "eslint"
  },
  "prisma": {
    "schema": "./prisma/schema.prisma",
    "seed": "node --loader ts-node/esm prisma/seed/admin.ts"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.3.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/bcrypt": "^6.0.0",
    "autoprefixer": "^10.4.24",
    "bcrypt": "^6.0.0",
    "framer-motion": "^12.31.1",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "pg": "^8.20.0",
    "postcss": "^8.5.6",
    "prisma": "^7.5.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@types/node": "^20.19.31",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}